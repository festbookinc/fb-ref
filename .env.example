# Supabase (festbookinc@gmail.com 계정)
# https://supabase.com/dashboard 에서 프로젝트 생성 후 아래 값을 입력하세요.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# 서버 전용 (이미지 업로드/DB 쓰기) - Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth (Google 로그인)
# npx auth secret 으로 AUTH_SECRET 생성
# https://console.cloud.google.com/apis/credentials 에서 OAuth 클라이언트 ID 발급

AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# 로그인 허용 (둘 다 함께 사용 가능)
ALLOWED_EMAILS=festbookinc@gmail.com
ALLOWED_EMAIL_DOMAINS=festbook.co.kr
